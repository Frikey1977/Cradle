# 自动处理行尾符
* text=auto

# 源代码文件 - 使用 LF 换行符
*.ts text eol=lf
*.js text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.jsonc text eol=lf

# 配置文件 - 使用 LF 换行符
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.config text eol=lf

# Web 文件 - 使用 LF 换行符
*.html text eol=lf
*.htm text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf

# 脚本文件 - 使用 LF 换行符
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.ps1 text eol=lf

# 其他文本文件 - 使用 LF 换行符
*.txt text eol=lf
*.log text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.sql text eol=lf
*.graphql text eol=lf
*.gql text eol=lf

# Docker 文件 - 使用 LF 换行符
Dockerfile text eol=lf
.dockerignore text eol=lf

# 版本控制文件 - 使用 LF 换行符
.gitattributes text eol=lf
.gitignore text eol=lf
.gitmodules text eol=lf

# 编辑器配置文件 - 使用 LF 换行符
.editorconfig text eol=lf
.eslintrc* text eol=lf
.prettierrc* text eol=lf
.stylelintrc* text eol=lf
.tsconfig*.json text eol=lf
jsconfig*.json text eol=lf

# 包管理文件 - 使用 LF 换行符
package.json text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf
pnpm-workspace.yaml text eol=lf
cargo.toml text eol=lf
Cargo.lock text eol=lf
composer.json text eol=lf
composer.lock text eol=lf

# 二进制文件 - 不处理换行符
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.rar binary
*.7z binary
*.bz2 binary
*.xz binary

# 音频/视频文件 - 不处理换行符
*.mp3 binary
*.mp4 binary
*.avi binary
*.mov binary
*.wmv binary
*.flv binary
*.wav binary
*.ogg binary
*.webm binary

# 字体文件 - 不处理换行符
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# 可执行文件 - 不处理换行符
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.bin binary

# 文档文件 - 不处理换行符
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
