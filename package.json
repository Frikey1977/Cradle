{
  "name": "cradle",
  "version": "1.0.0",
  "private": true,
  "description": "Cradle - Enterprise Management System",
  "type": "module",
  "scripts": {
    "alter:module-table": "tsx scripts/alter-module-table.ts",
    "build": "tsc",
    "dev": "nodemon",
    "gateway:start": "node dist/gateway/index.js",
    "gateway:master": "tsx --no-cache -r dotenv/config src/gateway/cli.ts master",
    "gateway:worker": "tsx -r dotenv/config src/gateway/cli.ts worker",
    "gateway:build": "tsc -p src/gateway",
    "import:modules": "tsx scripts/import-modules.ts",
    "typecheck": "tsc --noEmit -p src/gateway"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^8.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.25.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.6.5",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.11",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
